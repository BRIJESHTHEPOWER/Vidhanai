# Frontend environment (Vite)
#
# Base URL of the VidhanAI backend. Every API call reads this.
# - Local dev: leave unset (the code falls back to http://127.0.0.1:8000).
# - Production: set this in your Vercel project settings to the Render URL,
#   e.g. https://vidhanai-backend.onrender.com   (no trailing slash)
#
# IMPORTANT: Vite inlines env vars at BUILD time, so this must be set in Vercel
# BEFORE you build/redeploy — changing it later requires a redeploy.
VITE_API_URL=http://127.0.0.1:8000

_cached_laws = None

def _get_all_laws():
    global _cached_laws
    if _cached_laws is None:
        _cached_laws = list(laws_collection.find({}))
    return _cached_laws

router = APIRouter()


from typing import Optional, List

# ══════════════════════════════════════════════
# 🔐 AUTH HELPER
# ══════════════════════════════════════════════
def get_current_user_email_optional(authorization: Optional[str] = Header(None)):
    if not authorization or not authorization.startswith("Bearer "):
        return None
    token = authorization.split("Bearer ")[1]
    try:
        secret = os.getenv("JWT_SECRET", "super-secret-nyaya-key")
        payload = jwt.decode(token, secret, algorithms=["HS256"])
        return payload.get("sub")
    except:
        return None


# ══════════════════════════════════════════════
# 📌 MODELS
# ══════════════════════════════════════════════
class Question(BaseModel):
    question: str
    mode: Optional[str] = "both"
    language: Optional[str] = "English"


# ══════════════════════════════════════════════
# 🧠 SMART SEARCH – keyword + semantic matching
# ══════════════════════════════════════════════
@router.get("/search-law")
def search_law(q: str = Query(..., min_length=1)):
    """
    Natural language search across IPC+BNS laws stored in MongoDB.
    Tries MongoDB text search first; falls back to keyword scoring.
    """
    if not q.strip():
        return []

    results = []

    # ── 1. MongoDB full-text search ──────────────────────────────
    try:
        cursor = laws_collection.find(
            {"$text": {"$search": q}},
            {"score": {"$meta": "textScore"}}
        ).sort([("score", {"$meta": "textScore"})]).limit(5)

        for doc in cursor:
            results.append(_serialize_law(doc))
    except Exception:
        pass

    # ── 2. Keyword scoring fallback (if text search returned < 2) ───
    if len(results) < 2:
        words = [w.lower() for w in re.split(r"\W+", q) if len(w) > 2]
        all_laws = _get_all_laws()
        scored = []
        for law in all_laws:
            score = 0
            combined = " ".join([
                law.get("title", ""),
                law.get("description", ""),
                law.get("simple_explanation", ""),
                " ".join(law.get("keywords", []))
            ]).lower()
            for word in words:
                if word in combined:
                    score += 1
                # keyword field exact match gets bonus
                if word in [k.lower() for k in law.get("keywords", [])]:
                    score += 2
            if score > 0:
                scored.append((score, law))

        scored.sort(key=lambda x: x[0], reverse=True)
        seen_ids = {r["id"] for r in results}
        for score, law in scored[:5]:
            s = _serialize_law(law)
            if s["id"] not in seen_ids:
                results.append(s)
                seen_ids.add(s["id"])

    # ── 3. Cap at 5 ──────────────────────────────────────────────
    return results[:5]


# ══════════════════════════════════════════════
# 🔍 GET SECTION DETAIL
# ══════════════════════════════════════════════
@router.get("/get-section/{section_id}")
def get_section(section_id: str):
    """Return full detail for a specific law by MongoDB _id."""
    try:
        doc = laws_collection.find_one({"_id": ObjectId(section_id)})
        if not doc:
            # try ipc_section or bns_section field
            doc = laws_collection.find_one({"ipc_section": section_id})
        if not doc:
            doc = laws_collection.find_one({"bns_section": section_id})
        if not doc:
            raise HTTPException(status_code=404, detail="Section not found")
        return _serialize_law(doc, full=True)
    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=404, detail="Section not found")


# ══════════════════════════════════════════════
# ⚖️  IPC vs BNS COMPARISON
# ══════════════════════════════════════════════
@router.get("/compare-laws")
def compare_laws(ipc: Optional[str] = None, bns: Optional[str] = None, q: Optional[str] = None):
    """
    Returns IPC vs BNS side-by-side comparison.
    Can search by ipc_section, bns_section, or keyword query.
    Returns up to 5 comparison pairs.
    """
    results = []

    if ipc:
        doc = laws_collection.find_one({"ipc_section": ipc.strip()})
        if doc:
            results.append(_serialize_law(doc, full=True))

    elif bns:
        doc = laws_collection.find_one({"bns_section": bns.strip()})
        if doc:
            results.append(_serialize_law(doc, full=True))

    elif q:
        words = [w.lower() for w in re.split(r"\W+", q) if len(w) > 2]
        all_laws = _get_all_laws()
        scored = []
        for law in all_laws:
            score = 0
            combined = " ".join([
                law.get("title", ""),
                " ".join(law.get("keywords", []))
            ]).lower()
            for word in words:
                if word in combined:
                    score += 1
            if score > 0:
                scored.append((score, law))
        scored.sort(key=lambda x: x[0], reverse=True)
        for _, law in scored[:5]:
            results.append(_serialize_law(law, full=True))

    else:
        # Return random sample for browsing
        all_laws = _get_all_laws()
        sample = random.sample(all_laws, min(5, len(all_laws)))
        for law in sample:
            results.append(_serialize_law(law, full=True))

    return results



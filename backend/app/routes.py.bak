@router.get("/learn/topics")
def get_learn_topics(category: Optional[str] = None):
    """Return all IPC laws as topic cards grouped by category."""
    all_laws = _get_all_laws()
    results = []
    for law in all_laws:
        cat = law.get("category", "general_provisions")
        if category and cat != category:
            continue
        cat_info = CATEGORY_LABELS.get(cat, {"label": cat, "color": "#94a3b8", "icon": "📜"})
        results.append({
            "id":          str(law["_id"]),
            "ipc_section": law.get("ipc_section"),
            "bns_section": law.get("bns_section"),
            "title":       law.get("title"),
            "category":    cat,
            "category_label": cat_info["label"],
            "category_color": cat_info["color"],
            "category_icon":  cat_info["icon"],
            "punishment":  law.get("punishment"),
            "simple_explanation": law.get("simple_explanation", "")[:120] + "…",
            "bailable":    law.get("bailable"),
            "cognizable":  law.get("cognizable"),
            "keywords":    law.get("keywords", [])[:4],
        })
    return {"total": len(results), "topics": results}


@router.get("/learn/topic/{ipc_section}")
def get_learn_scenario(ipc_section: str):
    """Generate/return 4-step scenario for a given IPC section."""
    # Try by ipc_section first, then bns_section
    law = laws_collection.find_one({"ipc_section": ipc_section})
    if not law:
        law = laws_collection.find_one({"bns_section": ipc_section})
    if not law:
        raise HTTPException(status_code=404, detail=f"Section {ipc_section} not found")

    steps = generate_scenario(law)
    return {
        "ipc_section": law.get("ipc_section"),
        "bns_section": law.get("bns_section"),
        "title":       law.get("title"),
        "category":    law.get("category"),
        "punishment":  law.get("punishment"),
        "steps":       steps,
    }


@router.get("/quiz/generate")
def generate_quiz(count: int = 10, category: Optional[str] = None):
    """
    Auto-generate MCQ quiz questions from the dataset.
    No AI call needed — purely dataset-driven.
    """
    all_laws = _get_all_laws()

    # Filter by category if provided
    pool = [l for l in all_laws if not category or l.get("category") == category]
    if len(pool) < 4:
        pool = all_laws  # fallback to all

    # Shuffle and pick `count` questions
    import random as _random
    sample = list(pool)
    _random.shuffle(sample)
    questions = []

    all_punishments = list({l.get("punishment", "") for l in all_laws if l.get("punishment")})

    for law in sample[:count]:
        correct = law.get("punishment", "As per court")
        # Pick 3 distractors (different from correct)
        distractors = [p for p in (QUIZ_DISTRACTOR_POOL + all_punishments) if p != correct]
        _random.shuffle(distractors)
        distractors = distractors[:3]

        options = [correct] + distractors
        _random.shuffle(options)

        q_types = [
            {
                "question": f"What is the punishment for '{law.get('title')}' under IPC §{law.get('ipc_section')}?",
                "type": "punishment",
            },
            {
                "question": f"Under which IPC section is '{law.get('title')}' defined?",
                "type": "section",
                "correct_override": f"IPC §{law.get('ipc_section')}",
                "options_override": [
                    f"IPC §{law.get('ipc_section')}",
                    f"IPC §{_random.choice([l.get('ipc_section') for l in all_laws if l.get('ipc_section') != law.get('ipc_section')])}",
                    f"IPC §{_random.choice([l.get('ipc_section') for l in all_laws if l.get('ipc_section') != law.get('ipc_section')])}",
                    f"IPC §{_random.choice([l.get('ipc_section') for l in all_laws if l.get('ipc_section') != law.get('ipc_section')])}",
                ],
            },
        ]
        chosen = _random.choice(q_types)

        if chosen["type"] == "section":
            opts = chosen["options_override"]
            _random.shuffle(opts)
            # Deduplicate
            seen = set()
            deduped = []
            for o in opts:
                if o not in seen:
                    seen.add(o)
                    deduped.append(o)
            while len(deduped) < 4:
                deduped.append(f"IPC §{_random.randint(100,500)}")
            opts = deduped[:4]
            correct_ans = chosen["correct_override"]
        else:
            opts = options
            correct_ans = correct

        # Label A/B/C/D
        labeled = [{"label": chr(65+i), "text": o} for i, o in enumerate(opts)]
        correct_label = next((o["label"] for o in labeled if o["text"] == correct_ans), "A")

        questions.append({
            "id":            str(law["_id"]),
            "ipc_section":   law.get("ipc_section"),
            "bns_section":   law.get("bns_section"),
            "title":         law.get("title"),
            "category":      law.get("category"),
            "question":      chosen["question"],
            "options":       labeled,
            "correct":       correct_label,
            "explanation":   (
                f"Under IPC §{law.get('ipc_section')} / BNS §{law.get('bns_section')}: "
                f"{law.get('simple_explanation', law.get('description', ''))}"
            ),
        })

    return {"total": len(questions), "questions": questions}


@router.get("/explore/law/{ipc_section}")
def get_explore_law(ipc_section: str):
    """Return complete law data for Explore Mode."""
    law = laws_collection.find_one({"ipc_section": ipc_section})
    if not law:
        law = laws_collection.find_one({"bns_section": ipc_section})
    if not law:
        raise HTTPException(status_code=404, detail=f"Section {ipc_section} not found")

    cat = law.get("category", "general_provisions")
    cat_info = CATEGORY_LABELS.get(cat, {"label": cat, "color": "#94a3b8", "icon": "📜"})

    return {
        "id":              str(law["_id"]),
        "ipc_section":     law.get("ipc_section"),
        "bns_section":     law.get("bns_section"),
        "title":           law.get("title"),
        "category":        cat,
        "category_label":  cat_info["label"],
        "category_color":  cat_info["color"],
        "category_icon":   cat_info["icon"],
        "description":     law.get("description"),
        "bns_description": law.get("bns_description"),
        "punishment":      law.get("punishment"),
        "bns_punishment":  law.get("bns_punishment"),
        "simple_explanation": law.get("simple_explanation"),
        "real_life_example":  law.get("real_life_example"),
        "keywords":        law.get("keywords", []),
        "related_laws":    law.get("related_laws", []),
        "differences":     law.get("differences"),
        "bailable":        law.get("bailable"),
        "cognizable":      law.get("cognizable"),
    }


class AskSectionModel(BaseModel):
    ipc_section: str
    question: str
    language: Optional[str] = "English"

@router.post("/learn/ask-ai")
def learn_ask_ai(body: AskSectionModel):
    """AI follow-up question for a specific IPC section."""
    law = laws_collection.find_one({"ipc_section": body.ipc_section})
    if not law:
        law = laws_collection.find_one({"bns_section": body.ipc_section})

    if law:
        context = (
            f"Law: {law.get('title')}\n"
            f"IPC §{law.get('ipc_section')} / BNS §{law.get('bns_section')}\n"
            f"Description: {law.get('description')}\n"
            f"Punishment: {law.get('punishment')}\n"
            f"Simple Explanation: {law.get('simple_explanation')}\n"
            f"Real Life Example: {law.get('real_life_example', '')}"
        )
    else:
        context = _rag_context_from_db(body.question) or ""

    if not context:
        return {"answer": "I couldn't find relevant legal information for this question."}

    answer = generate_ai_response(body.question, context, body.language)
    return {"answer": answer, "ipc_section": body.ipc_section}


# ══════════════════════════════════════════════
# 🌐 TRANSLATION ENDPOINT
# ══════════════════════════════════════════════
class TranslateRequest(BaseModel):
    text: str
    target_language: str
    context: Optional[str] = ""

@router.post("/translate")
def translate_text(body: TranslateRequest):
    """
    Translate arbitrary text to the target language using Groq AI.
    Supports: English, Hindi, Kannada, Tamil, Telugu, Marathi, Bengali
    """
    if not body.text or not body.text.strip():
        return {"translated": "", "language": body.target_language}

    if body.target_language.lower() == "english":
        return {"translated": body.text, "language": "English"}

    try:
        from app.services.ai import generate_translation
        translated = generate_translation(body.text, body.target_language, body.context)
        return {"translated": translated, "language": body.target_language}
    except Exception as e:
        print("Translation Error:", e)
        return {"translated": body.text, "language": body.target_language, "error": str(e)}


# ══════════════════════════════════════════════
# 🎙️ VOICE ASK ENDPOINT
# ══════════════════════════════════════════════
class VoiceAskRequest(BaseModel):
    transcript: str
    language: Optional[str] = "English"

@router.post("/voice/ask")
def voice_ask(data: VoiceAskRequest, user_email: Optional[str] = Depends(get_current_user_email_optional)):
    """Process a voice transcript through RAG and return answer + story."""
    question = data.transcript.strip()
    if not question:
        return {"error": "Empty transcript"}

    context = _rag_context_from_db(question)
    if not context:
        context = find_relevant_law(question)

    if not context:
        return {"answer": "Sorry, I couldn't find relevant Indian law for that question.", "story": []}

    answer = generate_ai_response(question, context, data.language)
    story  = generate_story(context, question, data.language)

    # Save to history
    try:
        queries_collection.insert_one({
            "email": user_email,
            "question": question,
            "mode": "voice",
            "context": context,
            "answer": answer,
            "story": story,
            "language": data.language,
            "bookmarked": False,
            "created_at": datetime.utcnow()
        })
    except Exception:
        pass

    return {"answer": answer, "story": story, "language": data.language}


# ══════════════════════════════════════════════
# 🔧 HELPERS
# ══════════════════════════════════════════════
def _serialize_law(doc: dict, full: bool = False) -> dict:
    """Serialize MongoDB law doc for API response."""
    base = {
        "id": str(doc["_id"]),
        "ipc_section": doc.get("ipc_section"),
        "bns_section": doc.get("bns_section"),
        "title": doc.get("title"),
        "category": doc.get("category"),
        "punishment": doc.get("punishment"),
        "bns_punishment": doc.get("bns_punishment"),
        "simple_explanation": doc.get("simple_explanation"),
        "keywords": doc.get("keywords", []),
        "bailable": doc.get("bailable"),
        "cognizable": doc.get("cognizable"),
    }
    if full:
        base.update({
            "description": doc.get("description"),
            "bns_description": doc.get("bns_description"),
            "real_life_example": doc.get("real_life_example"),
            "related_laws": doc.get("related_laws", []),
            "differences": doc.get("differences"),
        })
    return base


def _rag_context_from_db(question: str) -> Optional[str]:
    """Try to get context from MongoDB laws first."""
    try:
        words = [w.lower() for w in re.split(r"\W+", question) if len(w) > 2]
        best_law = None
        max_score = 0

        all_laws = _get_all_laws()
        for law in all_laws:
            combined = " ".join([
                law.get("title", ""),
                law.get("description", ""),
                " ".join(law.get("keywords", [])),
                law.get("simple_explanation", "")
            ]).lower()
            score = sum(1 for w in words if w in combined)
            # Boost for keyword matches
            for kw in law.get("keywords", []):
                if kw.lower() in question.lower():
                    score += 3
            if score > max_score:
                max_score = score
                best_law = law

        if best_law and max_score > 0:
            return (
                f"Law: {best_law.get('title')}\n"
                f"IPC Section {best_law.get('ipc_section')} / BNS Section {best_law.get('bns_section')}\n"
                f"Description: {best_law.get('description')}\n"
                f"Punishment: {best_law.get('punishment')}\n"
                f"BNS Punishment: {best_law.get('bns_punishment')}\n"
                f"Simple Explanation: {best_law.get('simple_explanation')}\n"
                f"Key Differences (IPC vs BNS): {best_law.get('differences', '')}"
            )
    except Exception:
        pass
    return None
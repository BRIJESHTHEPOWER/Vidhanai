@router.get("/awareness")
def get_awareness(category: Optional[str] = None):
    """
    Return Know Your Rights awareness data.
    If category specified: return laws for that category.
    Otherwise: return all category overviews.
    """
    if category and category in AWARENESS_CATEGORIES:
        cat_info = AWARENESS_CATEGORIES[category]
        db_categories = cat_info["categories"]

        laws = []
        for db_cat in db_categories:
            cursor = laws_collection.find({"category": db_cat}).limit(10)
            for doc in cursor:
                laws.append(_serialize_law(doc, full=True))

        return {
            "category": category,
            "title": cat_info["title"],
            "icon": cat_info["icon"],
            "color": cat_info["color"],
            "description": cat_info["description"],
            "tips": QUICK_TIPS.get(category, []),
            "laws": laws
        }

    # Return all category overviews with law counts
    categories_data = []
    for key, info in AWARENESS_CATEGORIES.items():
        count = 0
        for db_cat in info["categories"]:
            count += laws_collection.count_documents({"category": db_cat})
        categories_data.append({
            "key": key,
            "title": info["title"],
            "icon": info["icon"],
            "color": info["color"],
            "description": info["description"],
            "law_count": count,
            "tips_count": len(QUICK_TIPS.get(key, []))
        })

    return {"categories": categories_data}


# ══════════════════════════════════════════════
# 🔍 AUTOCOMPLETE SUGGESTIONS
# ══════════════════════════════════════════════
@router.get("/suggest")
def suggest(query: str):
    BASE_DIR = os.path.dirname(os.path.dirname(__file__))
    file_path = os.path.join(BASE_DIR, "data", "ipc.json")

    q = query.lower().strip()
    suggestions = []

    # ── From MongoDB laws ───────────────────────────────────────
    try:
        cursor = laws_collection.find(
            {"$or": [
                {"title": {"$regex": q, "$options": "i"}},
                {"keywords": {"$elemMatch": {"$regex": q, "$options": "i"}}}
            ]}
        ).limit(4)
        for doc in cursor:
            ipc = doc.get("ipc_section", "")
            bns = doc.get("bns_section", "")
            title = doc.get("title", "")
            suggestions.append(f"IPC {ipc}/BNS {bns} - {title}")
    except Exception:
        pass

    # ── From ipc.json ───────────────────────────────────────────
    if len(suggestions) < 5 and os.path.exists(file_path):
        with open(file_path, "r", encoding="utf-8") as f:
            laws = json.load(f)
        for law in laws:
            if q in law.get("section_title", "").lower():
                suggestions.append(f"IPC {law['Section']} - {law['section_title']}")
            if len(suggestions) >= 7:
                break

    return list(dict.fromkeys(suggestions))[:6]  # deduplicate, cap at 6


# ══════════════════════════════════════════════
# 📜 LAW OF THE DAY
# ══════════════════════════════════════════════
@router.get("/law-of-day")
def law_of_day():
    # Prefer from our rich BNS dataset
    try:
        count = laws_collection.count_documents({})
        if count > 0:
            skip = random.randint(0, count - 1)
            doc = laws_collection.find().skip(skip).limit(1)[0]
            return {
                "section": f"IPC {doc.get('ipc_section','?')} / BNS {doc.get('bns_section','?')}",
                "title": doc.get("title", ""),
                "description": doc.get("simple_explanation") or doc.get("description", ""),
                "ipc_section": doc.get("ipc_section"),
                "bns_section": doc.get("bns_section"),
                "category": doc.get("category", "")
            }
    except Exception:
        pass

    # Fallback to ipc.json
    BASE_DIR = os.path.dirname(os.path.dirname(__file__))
    file_path = os.path.join(BASE_DIR, "data", "ipc.json")
    with open(file_path, "r", encoding="utf-8") as f:
        laws = json.load(f)
    law = random.choice(laws)
    return {
        "section": law["Section"],
        "title": law["section_title"],
        "description": law["section_desc"],
        "ipc_section": law["Section"],
        "bns_section": None,
        "category": ""
    }


# ══════════════════════════════════════════════
# 🧠 MAIN ASK API (Groq RAG)
# ══════════════════════════════════════════════
@router.post("/ask")
def ask_question(
    data: Question,
    user_email: Optional[str] = Depends(get_current_user_email_optional)
):
    question = data.question
    mode = data.mode
    language = data.language

    # 🔍 Try Vector DB (FAISS) first, then fallback
    context = find_relevant_law(question)
    if not context:
        context = _rag_context_from_db(question)

    if not context:
        return {
            "question": question,
            "answer": "❌ This question is not related to Indian law." if mode in ["rag", "both"] else None,
            "story": [] if mode in ["comic", "both"] else None
        }

    answer = None
    story = None

    if mode in ["rag", "both"]:
        answer = generate_ai_response(question, context, language)

    if mode in ["comic", "both"]:
        story = generate_story(context, question, language)

    doc_id = None
    try:
        result = queries_collection.insert_one({
            "email": user_email,
            "question": question,
            "mode": mode,
            "context": context,
            "answer": answer,
            "story": story,
            "language": language,
            "bookmarked": False,
            "created_at": datetime.utcnow()
        })
        doc_id = str(result.inserted_id)
    except Exception as e:
        print("MongoDB Save Error:", e)

    return {
        "id": doc_id,
        "question": question,
        "context": context,
        "answer": answer,
        "story": story,
        "language": language
    }


# ══════════════════════════════════════════════
# 📜 CHAT HISTORY
# ══════════════════════════════════════════════
@router.get("/history")
def get_history(user_email: Optional[str] = Depends(get_current_user_email_optional)):
    if not user_email:
        return []
    try:
        cursor = queries_collection.find({"email": user_email}).sort("created_at", -1)
        results = []
        for doc in cursor:
            results.append({
                "id": str(doc["_id"]),
                "question": doc.get("question"),
                "answer": doc.get("answer"),
                "story": doc.get("story", []),
                "mode": doc.get("mode"),
                "language": doc.get("language", "English"),
                "bookmarked": doc.get("bookmarked", False),
                "created_at": doc.get("created_at").isoformat() if doc.get("created_at") else None
            })
        return results
    except Exception as e:
        print("History Fetch Error:", e)
        return []


# ══════════════════════════════════════════════
# 🔖 TOGGLE BOOKMARK
# ══════════════════════════════════════════════
@router.put("/bookmark/{history_id}")
def toggle_bookmark(
    history_id: str,
    user_email: Optional[str] = Depends(get_current_user_email_optional)
):
    if not user_email:
        raise HTTPException(status_code=401, detail="Unauthorized")
    try:
        query = {"_id": ObjectId(history_id), "email": user_email}
        doc = queries_collection.find_one(query)
        if not doc:
            raise HTTPException(status_code=404, detail="Query not found")
        new_val = not doc.get("bookmarked", False)
        queries_collection.update_one(query, {"$set": {"bookmarked": new_val}})
        return {"id": history_id, "bookmarked": new_val}
    except Exception:
        raise HTTPException(status_code=500, detail="Error toggling bookmark")


# ══════════════════════════════════════════════
# 📄 PDF EXPORT
# ══════════════════════════════════════════════
@router.get("/export-pdf/{history_id}")
def export_pdf(history_id: str):
    try:
        doc = queries_collection.find_one({"_id": ObjectId(history_id)})
        if not doc:
            raise HTTPException(status_code=404, detail="Query not found")

        buffer = io.BytesIO()
        p = canvas.Canvas(buffer, pagesize=letter)
        p.setFont("Helvetica-Bold", 16)
        y_position = 750

        def draw_text(text, fontsize=12, bold=False):
            nonlocal y_position
            if y_position < 50:
                p.showPage()
                y_position = 750
            p.setFont("Helvetica-Bold" if bold else "Helvetica", fontsize)
            lines = simpleSplit(text or "", "Helvetica-Bold" if bold else "Helvetica", fontsize, 500)
            for line in lines:
                if y_position < 50:
                    p.showPage()
                    p.setFont("Helvetica-Bold" if bold else "Helvetica", fontsize)
                    y_position = 750
                p.drawString(50, y_position, line)
                y_position -= (fontsize + 5)
            y_position -= 10

        draw_text("NyayaAI Legal Report", 20, True)
        y_position -= 20
        draw_text("Query:", 14, True)
        draw_text(doc.get("question", "N/A"))
        draw_text("AI Analysis:", 14, True)
        ans = str(doc.get("answer", "")).encode('ascii', 'ignore').decode('ascii')
        draw_text(ans)

        if doc.get("story"):
            draw_text("Visual Story Scenes:", 14, True)
            for s in doc.get("story", []):
                scene_text = f"{s.get('scene', '')}: {s.get('text', '')}"
                draw_text(scene_text.encode('ascii', 'ignore').decode('ascii'), 10)

        p.save()
        buffer.seek(0)
        headers = {'Content-Disposition': f'attachment; filename="NyayaAI_Report_{history_id}.pdf"'}
        return StreamingResponse(buffer, media_type="application/pdf", headers=headers)
    except Exception as e:
        print("PDF Gen Error:", e)
        raise HTTPException(status_code=500, detail="Failed to generate PDF")


